---
import RightArrowIcon from "./icons/RightArrowIcon.astro";

type Props = {
  slug: string;
  name: string;
  class?: string;
};
const { slug, name, class: className } = Astro.props;
---

<a
  title={name}
  href={slug}
  class:list={[
    className,
    "group relative flex w-full flex-1 select-none items-center justify-between gap-6 rounded-2xl border border-neutral-200 bg-neutral-50 px-5 py-4 text-balanced transition-all duration-300 hover:border-primary hover:bg-primary hover:shadow-lg active:scale-[0.98] md:p-6",
  ]}
>
  <div class="flex flex-col gap-2">
    <span
      class="line-clamp-2 w-full text-pretty font-semibold text-md transition-colors group-hover:text-ink md:text-lg"
      >{name}</span
    >
    <span
      class="w-full text-sm text-ink/60 group-hover:text-ink/80"
      ><slot /></span
    >
  </div>

  <div
    class="text-ink/40 transition-all duration-300 group-hover:translate-x-1 group-hover:text-ink"
  >
    <RightArrowIcon width={20} height={20} />
  </div>
</a>
