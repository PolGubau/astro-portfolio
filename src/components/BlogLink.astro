---
type Props = {
  slug: string;
  name: string;
  class?: string;
};
const { slug, name, class: className } = Astro.props;
---

<a
  title={name}
  href={slug}
  class:list={[
    className,
    "group inline-flex w-full items-center justify-between gap-3 rounded-lg border border-foreground/10 bg-foreground/5 px-4 py-3 text-sm font-medium transition-all hover:border-foreground/20 hover:bg-foreground/10 md:gap-4 md:px-5 md:py-3.5 md:text-base",
  ]}
>
  <span class="line-clamp-1 flex-1 text-left">{name}</span>

  <svg
    class="h-4 w-4 flex-shrink-0 transition-transform group-hover:translate-x-1"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M9 5l7 7-7 7"></path>
  </svg>
</a>
