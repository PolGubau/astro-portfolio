---
import Schema from "./Schema.astro";

interface BreadcrumbItem {
  name: string;
  url?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const breadcrumbData = {
  itemListElement: items.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    ...(item.url && { item: new URL(item.url, Astro.site).href }),
  })),
};
---

<nav aria-label="Breadcrumb" class="mb-4">
  <ol class="flex items-center gap-2 text-sm text-ink/50">
    {
      items.map((item, index) => (
        <li class="flex items-center gap-2">
          {index > 0 && <span class="text-ink/30">/</span>}
          {item.url ? (
            <a href={item.url} class="hover:text-ink transition-colors">
              {item.name}
            </a>
          ) : (
            <span class="font-medium text-ink">{item.name}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<Schema type="BreadcrumbList" data={breadcrumbData} />
