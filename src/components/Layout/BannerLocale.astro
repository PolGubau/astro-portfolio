---
// Suggests switching to the visitor's browser language when it differs from
// the page's locale. Detection and dismissal happen client-side (static site).
// The banner is rendered out of flow (position: fixed) so it never causes
// layout shift, and animates in/out via opacity + translate. Only routes with
// real translations are eligible; everything else stays English-only.
import {
  type Locale,
  getLocale,
  locales,
  localizePath,
  stripLocale,
} from "../../i18n/utils";

const locale = getLocale(Astro.currentLocale);
const base = stripLocale(Astro.url.pathname);

const translatedRoutes = ["/", "/about", "/ui", "/blog", "/projects"];
const enabled = translatedRoutes.includes(base);

// Copy is shown in the visitor's language, not the current page's.
const copy: Record<Locale, { message: string; cta: string; dismiss: string }> =
  {
    en: {
      message: "This site is also available in English.",
      cta: "View in English",
      dismiss: "Dismiss",
    },
    es: {
      message: "Esta web también está disponible en español.",
      cta: "Verla en español",
      dismiss: "Descartar",
    },
    ca: {
      message: "Aquest web també està disponible en català.",
      cta: "Veure-ho en català",
      dismiss: "Descartar",
    },
  };

const options = locales.map((l) => ({
  locale: l,
  href: localizePath(base, l),
  ...copy[l],
}));
---

{
  enabled && (
    <div class="pointer-events-none fixed inset-x-0 bottom-24 z-50 flex justify-center px-4 md:bottom-6">
      <div
        id="locale-banner"
        data-current={locale}
        role="status"
        aria-live="polite"
        class="locale-banner flex items-center gap-3 rounded-full border border-ink/10 bg-background/80 px-4 py-2 text-sm text-ink/70 shadow-lg shadow-ink/5 backdrop-blur-md"
      >
        <p id="locale-banner-text" class="m-0" />
        <a
          id="locale-banner-link"
          href="#"
          class="font-medium text-ink underline underline-offset-4 hover:opacity-70"
        />
        <button
          id="locale-banner-dismiss"
          type="button"
          aria-label={copy[locale].dismiss}
          class="ml-auto shrink-0 rounded-full p-1 text-ink/40 transition-colors hover:bg-ink/5 hover:text-ink"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
        <script
          type="application/json"
          id="locale-banner-data"
          set:html={JSON.stringify(options)}
        />
      </div>
    </div>
  )
}

<style>
  /* Out-of-flow toast: hidden by default (no layout shift, no flash), fades and
     slides in once JS confirms a better-matching locale. */
  .locale-banner {
    opacity: 0;
    transform: translateY(0.75rem);
    pointer-events: none;
    visibility: hidden;
    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      visibility 0s linear 0.3s;
  }
  .locale-banner.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    .locale-banner {
      transition:
        opacity 0.2s ease,
        visibility 0s linear 0.2s;
      transform: none;
    }
    .locale-banner.is-visible {
      transform: none;
    }
  }
</style>

<script>
  const banner = document.getElementById("locale-banner");
  if (banner) {
    const KEY = "locale-banner-dismissed";
    const current = banner.dataset.current;
    const raw = document.getElementById("locale-banner-data")?.textContent;
    const options: {
      locale: string;
      href: string;
      message: string;
      cta: string;
    }[] = JSON.parse(raw ?? "[]");
    const supported = options.map((o) => o.locale);

    if (!localStorage.getItem(KEY)) {
      const prefs = navigator.languages?.length
        ? navigator.languages
        : [navigator.language];
      let preferred: string | null = null;
      for (const pref of prefs) {
        const short = pref.toLowerCase().split("-")[0];
        if (supported.includes(short)) {
          preferred = short;
          break;
        }
      }

      const match = options.find((o) => o.locale === preferred);
      if (match && preferred !== current) {
        const text = document.getElementById("locale-banner-text");
        const link = document.getElementById("locale-banner-link");
        if (text) text.textContent = match.message;
        if (link) {
          link.textContent = match.cta;
          link.setAttribute("href", match.href);
        }
        // Defer one frame so the transition runs from the hidden base state.
        requestAnimationFrame(() => banner.classList.add("is-visible"));
      }
    }

    document
      .getElementById("locale-banner-dismiss")
      ?.addEventListener("click", () => {
        banner.classList.remove("is-visible");
        try {
          localStorage.setItem(KEY, "1");
        } catch {}
      });
  }
</script>
