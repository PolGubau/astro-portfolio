---
// Suggests switching to the visitor's browser language when it differs from
// the page's locale. Detection and dismissal happen client-side (static site),
// so English visitors never see layout shift — the bar is hidden until JS
// confirms a better-matching locale exists. Only routes with real translations
// are eligible; everything else stays English-only and shows nothing.
import {
  type Locale,
  getLocale,
  localizePath,
  locales,
  stripLocale,
} from "../../i18n/utils";

const locale = getLocale(Astro.currentLocale);
const base = stripLocale(Astro.url.pathname);

const translatedRoutes = ["/", "/about"];
const enabled = translatedRoutes.includes(base);

// Copy is shown in the visitor's language, not the current page's.
const copy: Record<Locale, { message: string; cta: string; dismiss: string }> =
  {
    en: {
      message: "This site is also available in English.",
      cta: "View in English",
      dismiss: "Dismiss",
    },
    es: {
      message: "Esta web también está disponible en español.",
      cta: "Verla en español",
      dismiss: "Descartar",
    },
    ca: {
      message: "Aquest web també està disponible en català.",
      cta: "Veure-ho en català",
      dismiss: "Descartar",
    },
  };

const options = locales.map((l) => ({ locale: l, href: localizePath(base, l), ...copy[l] }));
---

{
  enabled && (
    <div
      id="locale-banner"
      data-current={locale}
      hidden
      class="flex items-center justify-center gap-3 rounded-full border border-ink/10 bg-ink/[0.03] px-4 py-2 mb-4 text-sm text-ink/70"
    >
      <p id="locale-banner-text" class="m-0" />
      <a
        id="locale-banner-link"
        href="#"
        class="font-medium text-ink underline underline-offset-4 hover:opacity-70"
      />
      <button
        id="locale-banner-dismiss"
        type="button"
        aria-label={copy[locale].dismiss}
        class="ml-auto shrink-0 rounded-full p-1 text-ink/40 hover:text-ink hover:bg-ink/5 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
      <script type="application/json" id="locale-banner-data" set:html={JSON.stringify(options)} />
    </div>
  )
}

<script>
  const banner = document.getElementById("locale-banner");
  if (banner) {
    const KEY = "locale-banner-dismissed";
    const current = banner.dataset.current;
    const raw = document.getElementById("locale-banner-data")?.textContent;
    const options: {
      locale: string;
      href: string;
      message: string;
      cta: string;
    }[] = JSON.parse(raw ?? "[]");
    const supported = options.map((o) => o.locale);

    if (!localStorage.getItem(KEY)) {
      const prefs = navigator.languages?.length
        ? navigator.languages
        : [navigator.language];
      let preferred: string | null = null;
      for (const pref of prefs) {
        const short = pref.toLowerCase().split("-")[0];
        if (supported.includes(short)) {
          preferred = short;
          break;
        }
      }

      const match = options.find((o) => o.locale === preferred);
      if (match && preferred !== current) {
        const text = document.getElementById("locale-banner-text");
        const link = document.getElementById("locale-banner-link");
        if (text) text.textContent = match.message;
        if (link) {
          link.textContent = match.cta;
          link.setAttribute("href", match.href);
        }
        banner.hidden = false;
      }
    }

    document
      .getElementById("locale-banner-dismiss")
      ?.addEventListener("click", () => {
        banner.hidden = true;
        try {
          localStorage.setItem(KEY, "1");
        } catch {}
      });
  }
</script>
