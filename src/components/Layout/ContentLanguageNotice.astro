---
// Subtle inline notice for localized index pages whose listed content
// (articles / project details) is only available in English. Renders nothing
// when `message` is empty (i.e. for the English locale).
interface Props {
  message: string;
}

const { message } = Astro.props;
---

{
  message && (
    <p
      role="note"
      class="flex w-fit items-center gap-2 rounded-full border border-ink/[0.08] bg-ink/[0.025] px-3 py-1.5 text-xs text-ink/55"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-3.5 w-3.5 shrink-0"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="10" />
        <line x1="2" y1="12" x2="22" y2="12" />
        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
      </svg>
      <span>{message}</span>
    </p>
  )
}
