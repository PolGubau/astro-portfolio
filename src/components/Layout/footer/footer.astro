---
import { getLocale, localizePath, useTranslations } from "../../../i18n/utils";
import { metadata } from "../../../lib/constants";
import DownloadIcon from "../../icons/DownloadIcon.astro";
import LogoPill from "../../ui/LogoPill.astro";

const locale = getLocale(Astro.currentLocale);
const t = useTranslations(locale);

const year = new Date().getFullYear();

const nav = [
  { href: localizePath("/", locale), label: t("footer.home") },
  { href: localizePath("/projects", locale), label: t("footer.work") },
  { href: localizePath("/blog", locale), label: t("footer.writing") },
  { href: localizePath("/ui", locale), label: t("footer.experiments") },
];

const socials = [
  { href: metadata.links.email, label: t("footer.email"), me: false },
  { href: metadata.links.linkedin, label: "LinkedIn", me: true },
  { href: metadata.links.github, label: "GitHub", me: true },
];
---

<footer class="mt-24 md:mt-48 py-10 flex flex-col gap-8">
  <LogoPill />
  <div class="flex flex-col md:flex-row md:items-start justify-between gap-8">
    <div class="flex flex-col gap-4">
      <span class="font-medium flex flex-col gap-1">{metadata.longName}</span>
      <nav class="flex flex-wrap gap-x-6 gap-y-2">
        {
          nav.map(({ href, label }) => (
            <a
              href={href}
              class="text-sm text-ink/50 hover:text-ink transition-colors"
            >
              {label}
            </a>
          ))
        }
      </nav>
    </div>

    <!-- Right: socials + CV -->
    <div class="flex flex-wrap items-center gap-x-6 gap-y-3">
      {
        socials.map(({ href, label, me }) => (
          <a
            href={href}
            class="text-sm text-ink/50 hover:text-ink transition-colors"
            target="_blank"
            rel={me ? "me noopener noreferrer" : "noopener noreferrer"}
          >
            {label}
          </a>
        ))
      }
      <a
        href="/files/PolGubau_CV.pdf"
        download
        class="inline-flex items-center gap-1.5 rounded-full border border-ink/20 bg-ink/5 px-3.5 py-1.5 text-sm font-medium text-ink/70 transition-colors hover:border-ink/40 hover:bg-ink/10 hover:text-ink"
      >
        <DownloadIcon />
        CV
      </a>
    </div>
  </div>

  <p class="text-xs text-ink/30">© {year} {metadata.longName}</p>
</footer>
