---
import { getLocale, localizePath, useTranslations } from "../../../i18n/utils";
import { metadata } from "../../../lib/constants";
import DownloadIcon from "../../icons/DownloadIcon.astro";
import LogoPill from "../../ui/LogoPill.astro";
import LanguageToggle from "./LanguageToggle.astro";

const locale = getLocale(Astro.currentLocale);
const t = useTranslations(locale);

const year = new Date().getFullYear();

// Every route has a localized index variant; their links go through
// localizePath so the locale segment is preserved.
const nav = [
  { href: localizePath("/", locale), label: t("footer.home") },
  { href: localizePath("/projects", locale), label: t("footer.work") },
  { href: localizePath("/blog", locale), label: t("footer.writing") },
  { href: localizePath("/ui", locale), label: t("footer.experiments") },
];

const socials = [
  { href: metadata.links.email, label: t("footer.email"), me: false },
  { href: metadata.links.linkedin, label: "LinkedIn", me: true },
  { href: metadata.links.github, label: "GitHub", me: true },
];
---

<footer class="mt-24 md:mt-48 py-10 flex flex-col gap-8">
  <LogoPill />
  <div class="flex flex-col md:flex-row md:items-start justify-between gap-8">
    <div class="flex flex-col gap-4">
      <span class="font-medium flex flex-col gap-1">{metadata.longName}</span>
      <nav class="flex flex-wrap gap-x-6 gap-y-2">
        {
          nav.map(({ href, label }) => (
            <a
              href={href}
              class="text-sm text-ink/50 hover:text-ink transition-colors"
            >
              {label}
            </a>
          ))
        }
      </nav>
    </div>

    <!-- Right: socials + CV -->
    <div class="flex flex-wrap items-center gap-x-6 gap-y-3">
      {
        socials.map(({ href, label, me }) => (
          <a
            href={href}
            class="text-sm text-ink/50 hover:text-ink transition-colors"
            target="_blank"
            rel={me ? "me noopener noreferrer" : "noopener noreferrer"}
          >
            {label}
          </a>
        ))
      }
      <a
        href="/files/PolGubau_CV.pdf"
        download
        class="inline-flex items-center gap-1.5 rounded-full border border-ink/20 bg-ink/5 px-3.5 py-1.5 text-sm font-medium text-ink/70 transition-colors hover:border-ink/40 hover:bg-ink/10 hover:text-ink"
      >
        <DownloadIcon />
        CV
      </a>
    </div>
  </div>

  <div class="flex items-center justify-between gap-4">
    <p class="text-xs text-ink/30">© {year} {metadata.longName}</p>
    <div class="flex items-center gap-3">
      <LanguageToggle />

      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        type="button"
        aria-label={t("a11y.toggleTheme")}
        class="rounded-full border border-ink/10 p-1.5 text-ink/40 hover:text-ink hover:bg-ink/5 transition-colors duration-150"
      >
        <!-- Sun (shown in dark mode) -->
        <svg
          id="theme-icon-sun"
          xmlns="http://www.w3.org/2000/svg"
          class="hidden h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <!-- Moon (shown in light mode) -->
        <svg
          id="theme-icon-moon"
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </div>

  <script>
    const toggle = document.getElementById("theme-toggle");
    const sun = document.getElementById("theme-icon-sun");
    const moon = document.getElementById("theme-icon-moon");
    const html = document.documentElement;

    function applyTheme(dark: boolean) {
      html.classList.toggle("dark", dark);
      sun?.classList.toggle("hidden", !dark);
      moon?.classList.toggle("hidden", dark);
      localStorage.setItem("theme", dark ? "dark" : "light");
    }

    // Sync icon with current state on load
    applyTheme(html.classList.contains("dark"));

    toggle?.addEventListener("click", () => {
      applyTheme(!html.classList.contains("dark"));
    });
  </script>
</footer>
