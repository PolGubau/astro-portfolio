---
import { Image } from "astro:assets";
import me from "../../../assets/media/me.webp";
import { getLocale, useTranslations } from "../../../i18n/utils";

const locale = getLocale(Astro.currentLocale);
const t = useTranslations(locale);

const stats = [
  { value: "62k+", label: t("home.stats.npm") },
  { value: "1M+", label: t("home.stats.vercel") },
  {
    value: `${new Date().getFullYear() - 2019}+`,
    label: t("home.stats.years"),
  },
  { value: "55+", label: t("home.stats.react") },
];
---

<header class="flex flex-col gap-12 py-16 md:py-24">
  <!-- Name + Avatar -->
  <div
    class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8"
  >
    <div class="flex flex-col gap-4 max-w-2xl">
      <h1
        data-reveal="bottom"
        data-speed="fast"
        data-easing="soft"
        class="text-5xl md:text-6xl text-balance font-medium leading-[0.95]"
      >
        {t("home.hero.title")}
      </h1>
      <p
        data-reveal="bottom"
        data-delay="120"
        data-easing="soft"
        class="text-lg text-ink/60 max-w-lg"
        set:html={t("home.hero.intro")}
      />
    </div>

    <Image
      data-reveal="bottom"
      data-speed="fast"
      data-delay="80"
      src={me}
      class="rounded-full bg-primary object-cover"
      alt="Pol Gubau Amores"
      width={120}
      height={120}
      loading="eager"
      priority
    />
  </div>

  <!-- Stats -->
  <div
    data-reveal="bottom"
    data-delay="200"
    data-easing="soft"
    class="grid grid-cols-2 md:grid-cols-4 gap-px rounded-xl overflow-hidden border border-ink/20 divide-ink/20 divide-x"
  >
    {
      stats.map(({ value, label }) => (
        <div class="flex flex-col gap-1 px-6 py-5 bg-background">
          <span class="text-2xl md:text-3xl font-medium">{value}</span>
          <span class="text-sm text-ink/50">{label}</span>
        </div>
      ))
    }
  </div>
</header>
