---
import { Image } from "astro:assets";
import me from "../../../assets/media/me.webp";
import { metadata } from "../../../lib/constants";
import MainSocials from "../../Social/MainSocials.astro";

const thisYear = new Date().getFullYear();
const yearSince2018 = thisYear - 2018;
---

<header
  class="flex min-h-[80vh] flex-col items-center justify-center py-20 md:py-32"
>
  <div
    class="mx-auto flex w-full max-w-3xl flex-col items-center gap-8 text-center"
  >
    <!-- Professional Photo -->
    <div class="motion-preset-blur-up motion-delay-[100ms]">
      <Image
        src={me}
        class="h-28 w-28 rounded-full object-cover ring-4 ring-foreground/10 md:h-32 md:w-32"
        alt="Pol Gubau Amores"
        title="Pol Gubau Amores"
        width={128}
        height={128}
      />
    </div>

    <!-- Name -->
    <div class="motion-preset-blur-up motion-delay-[200ms]">
      <h1
        class="font-title text-4xl font-bold leading-tight tracking-tight md:text-6xl"
      >
        {metadata.longName}
      </h1>
    </div>

    <!-- Title/Role -->
    <div class="motion-preset-blur-up motion-delay-[300ms]">
      <h2 class="text-xl font-medium text-foreground/70 md:text-2xl">
        Co-Founder at Doscientos • Frontend Developer & Design Engineer
      </h2>
    </div>

    <!-- Bio -->
    <div class="motion-preset-blur-up motion-delay-[400ms]">
      <p
        class="max-w-2xl text-lg leading-relaxed text-foreground/60 md:text-xl"
      >
        Co-founder of <a
          href="https://doscientos.es"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold text-foreground hover:text-primary transition-colors underline decoration-foreground/30 underline-offset-4"
          >Doscientos</a
        >, a software development agency that has delivered solutions for 30+
        clients. Creator of <a
          href="https://pol-ui.com"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold text-foreground hover:text-primary transition-colors underline decoration-foreground/30 underline-offset-4"
          >Pol-UI</a
        >, an open-source React component library.
      </p>
    </div>

    <!-- Location & Status -->
    <div class="motion-preset-blur-up motion-delay-[500ms]">
      <p class="text-foreground/50">
        Barcelona, Spain • {yearSince2018}+ years of experience
      </p>
    </div>

    <!-- Social Links -->
    <div class="motion-preset-blur-up motion-delay-[600ms]">
      <MainSocials />
    </div>
  </div>
</header>
