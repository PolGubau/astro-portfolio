---
import { Image } from "astro:assets";
import me from "../../../assets/media/me.webp";

const stats = [
  { value: "62k+", label: "NPM downloads" },
  { value: "1M+", label: "Vercel requests/yr" },
  {
    value: `${new Date().getFullYear() - 2019}+`,
    label: "Years of experience",
  },
  { value: "55+", label: "React projects" },
];
---

<header class="flex flex-col gap-12 py-16 md:py-24">
  <!-- Name + Avatar -->
  <div
    class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8"
  >
    <div class="flex flex-col gap-4 max-w-2xl">
      <h1
        data-reveal="bottom"
        data-speed="fast"
        data-easing="soft"
        class="text-5xl md:text-6xl text-balance font-medium leading-[0.95]"
      >
        I'm Pol, a senior frontend developer
      </h1>
      <p
        data-reveal="bottom"
        data-delay="120"
        data-easing="soft"
        class="text-lg text-ink/60 max-w-lg"
      >
        Senior Frontend Engineer at <a
          href="https://mesalvo.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-ink hover:underline underline-offset-4">Mesalvo</a
        >. Co-founder of <a
          href="https://doscientos.es"
          target="_blank"
          rel="noopener noreferrer"
          class="text-ink hover:underline underline-offset-4">Doscientos</a
        >. Based in Mataró, Barcelona.
      </p>
    </div>

    <Image
      data-reveal="bottom"
      data-speed="fast"
      data-delay="80"
      src={me}
      class="rounded-full bg-primary object-cover"
      alt="Pol Gubau Amores"
      width={120}
      height={120}
      loading="eager"
      priority
    />
  </div>

  <!-- Stats -->
  <div
    data-reveal="bottom"
    data-delay="200"
    data-easing="soft"
    class="grid grid-cols-2 md:grid-cols-4 gap-px bg-neutral-200 rounded-xl overflow-hidden border border-neutral-200"
  >
    {
      stats.map(({ value, label }) => (
        <div class="flex flex-col gap-1 px-6 py-5 bg-background">
          <span class="text-2xl md:text-3xl font-medium">{value}</span>
          <span class="text-sm text-ink/50">{label}</span>
        </div>
      ))
    }
  </div>
</header>
