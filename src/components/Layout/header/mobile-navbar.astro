---
import {
  getLocale,
  localizePath,
  stripLocale,
  useTranslations,
} from "../../../i18n/utils";

const locale = getLocale(Astro.currentLocale);
const t = useTranslations(locale);

// Compare against the locale-agnostic path so the active state is independent
// of the language segment (`/es/blog` -> `/blog`).
const pathname = stripLocale(
  Astro.url.pathname.replace(import.meta.env.BASE_URL, ""),
);
const section = pathname.match(/[^\/]+/g)?.[0];

// Routes are stored locale-agnostic and localized at render time via
// localizePath so the locale segment is preserved in the href.
const navItems = [
  { path: "/", name: t("m.home") },
  { path: "/about", name: t("m.about") },
  { path: "/projects", name: t("m.work") },
  { path: "/ui", name: t("m.lab") },
  { path: "/blog", name: t("m.writing") },
];
---

<footer
  class="fixed bottom-0 left-0 right-0 z-[999] md:hidden safe-area-inset-bottom"
>
  <nav
    class="mx-auto flex max-w-md items-center justify-around border-t border-ink/10 bg-background/90 px-4 py-4 backdrop-blur-xl"
  >
    {
      navItems.map(({ path, name }) => {
        const isActive =
          path === pathname || (path !== "/" && path === `/${section ?? ""}`);
        return (
          <a
            href={localizePath(path, locale)}
            aria-current={isActive ? "page" : undefined}
            tabindex={isActive ? -1 : undefined}
            class:list={[
              "flex flex-col items-center gap-1.5 transition-colors duration-200",
              {
                "text-ink font-medium": isActive,
              },
              {
                "text-ink/40": !isActive,
              },
            ]}
          >
            <span class="text-xs">{name}</span>
            {isActive && <span class="h-0.5 w-4 rounded-full bg-ink" />}
          </a>
        );
      })
    }
  </nav>
</footer>
