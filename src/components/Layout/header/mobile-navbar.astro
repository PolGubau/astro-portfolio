---
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
const subpath = pathname.match(/[^\/]+/g);

const navItems = [
  { path: "/", name: "Home" },
  { path: "/projects", name: "Work" },
  { path: "/ui", name: "Experiments" },
  { path: "/blog", name: "Writing" },
];
---

<footer
  class="fixed bottom-0 left-0 right-0 md:hidden safe-area-inset-bottom"
  style="z-index: 999;"
>
  <nav
    class="mx-auto flex max-w-md items-center justify-around border-t border-foreground/10 bg-background/95 px-2 py-3 backdrop-blur-xl"
  >
    {
      navItems.map(({ path, name }) => {
        const isActive = path === pathname || path === `/${subpath?.[0] || ""}`;
        return (
          <a
            href={path}
            tabindex={isActive ? -1 : undefined}
            class:list={[
              "flex flex-1 flex-col items-center gap-1 rounded-xl px-3 py-2 transition-all duration-200 active:scale-95",
              {
                "text-foreground": isActive,
              },
              {
                "text-foreground/50 active:text-foreground/70": !isActive,
              },
            ]}
          >
            <span class="text-xs font-medium">{name}</span>
            {isActive && <span class="h-1 w-1 rounded-full bg-foreground" />}
          </a>
        );
      })
    }
  </nav>
</footer>
