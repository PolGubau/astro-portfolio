---
import { getLocale, localizePath, useTranslations } from "../../../i18n/utils";

const locale = getLocale(Astro.currentLocale);
const t = useTranslations(locale);

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
const subpath = pathname.match(/[^\/]+/g);

// "/", "/about" and "/ui" have localized variants; projects/blog list
// English-only content, so they always point to the English route.
const navItems = [
  { path: localizePath("/", locale), name: t("m.home") },
  { path: localizePath("/about", locale), name: t("m.about") },
  { path: "/projects", name: t("m.work") },
  { path: localizePath("/ui", locale), name: t("m.lab") },
  { path: "/blog", name: t("m.writing") },
];
---

<footer
  class="fixed bottom-0 left-0 right-0 z-[999] md:hidden safe-area-inset-bottom"
>
  <nav
    class="mx-auto flex max-w-md items-center justify-around border-t border-ink/10 bg-background/90 px-4 py-4 backdrop-blur-xl"
  >
    {
      navItems.map(({ path, name }) => {
        const isActive = path === pathname || path === `/${subpath?.[0] || ""}`;
        return (
          <a
            href={path}
            tabindex={isActive ? -1 : undefined}
            class:list={[
              "flex flex-col items-center gap-1.5 transition-colors duration-200",
              {
                "text-ink font-medium": isActive,
              },
              {
                "text-ink/40": !isActive,
              },
            ]}
          >
            <span class="text-xs">{name}</span>
            {isActive && <span class="h-0.5 w-4 rounded-full bg-ink" />}
          </a>
        );
      })
    }
  </nav>
</footer>
