---
import NavItem from "./NavItem.astro";

const navItems = {
  "/": { name: "Home" },
  "/projects": { name: "Work" },
  "/ui": { name: "Experiments" },
  "/blog": { name: "Writing" },
};
---

<aside class="mb-16 flex justify-center tracking-tight md:justify-start">
  <div class="sticky top-20">
    <nav
      class="relative inline-flex items-center gap-1 rounded-full border border-foreground/10 bg-background/80 p-1 shadow-sm backdrop-blur-md"
    >
      {
        Object.entries(navItems).map(([path, { name }]) => {
          return <NavItem path={path} name={name} />;
        })
      }
    </nav>
  </div>
</aside>
