---
import { getLocale, localizePath, useTranslations } from "../../../i18n/utils";
import LogoPill from "../../ui/LogoPill.astro";

const locale = getLocale(Astro.currentLocale);
const t = useTranslations(locale);

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
const subpath = pathname.match(/[^\/]+/g);

// "/", "/about" and "/ui" have localized variants; projects/blog list
// English-only content, so they always point to the English route.
const navItems = [
  { path: localizePath("/", locale), name: t("nav.home") },
  { path: localizePath("/about", locale), name: t("nav.about") },
  { path: "/projects", name: t("nav.portfolio") },
  { path: localizePath("/ui", locale), name: t("nav.experiments") },
  { path: "/blog", name: t("nav.writing") },
];
---

<header
  class="sticky top-4 z-50 mb-12 flex items-center justify-between max-md:hidden"
>
  <LogoPill />

  <nav
    class="flex items-center gap-1 rounded-full border border-ink/[0.06] bg-background/75 p-1.5 backdrop-blur-md shadow-sm"
  >
    {
      navItems.map(({ path, name }) => {
        const isActive = path === pathname || path === `/${subpath?.[0] || ""}`;
        return (
          <a
            href={path}
            class:list={[
              "rounded-full px-4 py-1.5 text-sm transition-all duration-200",
              {
                "bg-ink text-background font-medium shadow-sm": isActive,
              },
              {
                "text-ink/50 hover:text-ink hover:bg-ink/5": !isActive,
              },
            ]}
          >
            {name}
          </a>
        );
      })
    }

    <!-- Dark mode toggle -->
    <button
      id="theme-toggle"
      type="button"
      aria-label={t("a11y.toggleTheme")}
      class="ml-1 rounded-full p-1.5 text-ink/50 hover:text-ink hover:bg-ink/5 transition-all duration-200"
    >
      <!-- Sun (shown in dark mode) -->
      <svg
        id="theme-icon-sun"
        xmlns="http://www.w3.org/2000/svg"
        class="hidden h-4 w-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
      <!-- Moon (shown in light mode) -->
      <svg
        id="theme-icon-moon"
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>
  </nav>

  <script>
    const toggle = document.getElementById("theme-toggle");
    const sun = document.getElementById("theme-icon-sun");
    const moon = document.getElementById("theme-icon-moon");
    const html = document.documentElement;

    function applyTheme(dark: boolean) {
      html.classList.toggle("dark", dark);
      sun?.classList.toggle("hidden", !dark);
      moon?.classList.toggle("hidden", dark);
      localStorage.setItem("theme", dark ? "dark" : "light");
    }

    // Sync icon with current state on load
    applyTheme(html.classList.contains("dark"));

    toggle?.addEventListener("click", () => {
      applyTheme(!html.classList.contains("dark"));
    });
  </script>
</header>
