---
import {
  getLocale,
  localizePath,
  stripLocale,
  useTranslations,
} from "../../../i18n/utils";
import LogoPill from "../../ui/LogoPill.astro";

const locale = getLocale(Astro.currentLocale);
const t = useTranslations(locale);

// Compare against the locale-agnostic path so the active state is independent
// of the language segment (`/es/blog` -> `/blog`).
const pathname = stripLocale(
  Astro.url.pathname.replace(import.meta.env.BASE_URL, ""),
);
const section = pathname.match(/[^\/]+/g)?.[0];

// Routes are stored locale-agnostic and localized at render time via
// localizePath so the locale segment is preserved in the href.
const navItems = [
  { path: "/", name: t("nav.home") },
  { path: "/about", name: t("nav.about") },
  { path: "/projects", name: t("nav.portfolio") },
  { path: "/ui", name: t("nav.experiments") },
  { path: "/blog", name: t("nav.writing") },
];
---

<header
  class="sticky top-4 z-50 mb-12 flex items-center justify-between max-md:hidden"
>
  <LogoPill />

  <nav
    class="flex items-center rounded-full border border-ink/[0.06] bg-background/75 p-1 backdrop-blur-sm shadow-sm"
  >
    {
      navItems.map(({ path, name }) => {
        const isActive =
          path === pathname || (path !== "/" && path === `/${section ?? ""}`);
        return (
          <a
            href={localizePath(path, locale)}
            aria-current={isActive ? "page" : undefined}
            class:list={[
              "rounded-full px-4 py-1 text-sm transition-all duration-200",
              {
                "bg-ink text-background font-medium shadow-sm": isActive,
              },
              {
                "text-ink/50 hover:text-ink hover:bg-ink/5": !isActive,
              },
            ]}
          >
            {name}
          </a>
        );
      })
    }
  </nav>
</header>
