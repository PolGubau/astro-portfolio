---
import LogoPill from "../../ui/LogoPill.astro";

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
const subpath = pathname.match(/[^\/]+/g);

const navItems = [
  { path: "/", name: "Home" },
  { path: "/about", name: "About" },
  { path: "/projects", name: "Portfolio" },
  { path: "/ui", name: "Experiments" },
  { path: "/blog", name: "Writing" },
];
---

<header class="sticky top-4 z-50 mb-12">
  <div
    class="flex w-full items-center justify-between rounded-2xl border border-ink/[0.06] bg-background/75 p-1.5 pl-4 backdrop-blur-md shadow-sm"
  >
    <LogoPill />

    <nav class="flex items-center gap-1 pr-1">
      {
        navItems.map(({ path, name }) => {
          const isActive =
            path === pathname || path === `/${subpath?.[0] || ""}`;
          return (
            <a
              href={path}
              class:list={[
                "rounded-xl px-3 py-1.5 text-sm transition-colors duration-200",
                {
                  "bg-ink text-background font-medium": isActive,
                },
                {
                  "text-ink/50 hover:text-ink hover:bg-ink/5": !isActive,
                },
              ]}
            >
              {name}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
