---
import ThemeToggle from "../../ThemeToggle.astro";

const navItems = {
  "/": { name: "Home" },
  "/projects": { name: "Work" },
  "/blog": { name: "Writing" },
  "/ui": { name: "Experiments" },
  "/about": { name: "About" },
};

const currentPath = Astro.url.pathname;
---

<nav
  class="sticky top-0 z-50 border-b border-foreground/10 bg-background/80 backdrop-blur-md motion-preset-blur-up motion-delay-[50ms]"
>
  <div
    class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4 md:px-10"
  >
    <!-- Logo/Name -->
    <a
      href="/"
      class="font-title text-lg font-bold tracking-tight transition-colors hover:text-primary"
    >
      Pol Gubau
    </a>

    <!-- Navigation Links + Theme Toggle -->
    <div class="flex items-center gap-2">
      {
        Object.entries(navItems).map(([path, { name }]) => {
          const isActive =
            currentPath === path ||
            (path !== "/" && currentPath.startsWith(path));
          return (
            <a
              href={path}
              class={`rounded-lg px-4 py-2 text-sm font-medium transition-all ${
                isActive
                  ? "bg-foreground/10 text-foreground"
                  : "text-foreground/60 hover:bg-foreground/5 hover:text-foreground"
              }`}
            >
              {name}
            </a>
          );
        })
      }

      <!-- Theme Toggle -->
      <ThemeToggle />
    </div>
  </div>
</nav>
