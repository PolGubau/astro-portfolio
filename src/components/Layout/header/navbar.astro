---
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
const subpath = pathname.match(/[^\/]+/g);

const navItems = [
  { path: "/", name: "Home" },
  { path: "/projects", name: "Portfolio" },
  { path: "/ui", name: "Experiments" },
  { path: "/blog", name: "Writing" },
];
---

<nav class="mb-20 flex justify-end items-center gap-8 text-sm">
  {
    navItems.map(({ path, name }) => {
      const isActive = path === pathname || path === `/${subpath?.[0] || ""}`;
      return (
        <a
          href={path}
          class:list={[
            "transition-colors duration-200",
            {
              "text-foreground font-medium": isActive,
            },
            {
              "text-foreground/50 hover:text-foreground": !isActive,
            },
          ]}
        >
          {name}
        </a>
      );
    })
  }
</nav>
