---
import { Icon } from "astro-icon/components";
import { getLocale, useTranslations } from "../../i18n/utils";
import type { ProjectMetadata } from "../../lib/utils";
import GithubIcon from "../icons/GithubIcon.astro";
import NpmIcon from "../icons/NpmIcon.astro";
import SearchIcon from "../icons/SearchIcon.astro";

interface Props {
  project: ProjectMetadata;
}
const { project } = Astro.props;
const data = project.data;
const locale = getLocale(Astro.currentLocale);
const t = useTranslations(locale);
---

<div
  class="fixed bottom-20 md:bottom-4 inset-x-0 flex justify-center px-4 pointer-events-none"
  id="project-bar"
>
  <div
    class="pointer-events-auto flex w-fit max-w-[calc(100vw-2rem)] items-center justify-between gap-4 md:gap-8 rounded-xl p-1 shadow-lg backdrop-blur bg-white/80 dark:bg-neutral-900/80 border border-neutral-200 dark:border-neutral-700"
    style={{ backgroundColor: data.color ?? "#808080" }}
  >
    <h2 class="pl-2 font-semibold text-xl text-black/80">{data.title}</h2>

    <ul class="flex items-center gap-1">
      <!-- Share button - native share API on mobile, clipboard fallback on desktop -->
      <li>
        <button
          id="share-button"
          type="button"
          aria-label={t("bar.share")}
          title={t("bar.share")}
          class="group relative flex items-center gap-1.5 cursor-pointer rounded-lg px-2.5 py-2 text-black/60 transition-all hover:bg-black/15"
        >
          <Icon
            name="lucide:share-2"
            class="share-icon w-4 h-4"
            aria-hidden="true"
          />
          <Icon
            name="lucide:check"
            class="check-icon w-4 h-4 hidden"
            aria-hidden="true"
          />
          <span class="feedback-label hidden text-xs font-medium"
            >{t("bar.copied")}</span
          >
        </button>
      </li>

      {
        data.npmLink && (
          <li>
            <a
              href={data.npmLink}
              title="NPM"
              target="_blank"
              rel="noopener noreferrer"
              class="flex aspect-square rounded-lg p-2 text-black/60 transition-all hover:bg-black/15"
            >
              <NpmIcon width={16} height={16} />
            </a>
          </li>
        )
      }
      {
        data.githubLink && (
          <li>
            <a
              href={data.githubLink}
              title="GitHub"
              target="_blank"
              rel="noopener noreferrer"
              class="flex aspect-square rounded-lg p-2 text-black/60 transition-all hover:bg-black/15"
            >
              <GithubIcon width={16} height={16} />
            </a>
          </li>
        )
      }
      {
        data.link && (
          <li>
            <a
              href={data.link}
              title={t("bar.visitProject")}
              target="_blank"
              rel="noopener noreferrer"
              class="flex aspect-square rounded-lg bg-black/20 p-2 transition-all hover:bg-black/30"
              style={{ color: data.color ?? "#808080" }}
            >
              <SearchIcon width={16} height={16} class="text-foreground" />
            </a>
          </li>
        )
      }
    </ul>
  </div>
</div>

<script>
  const btn = document.getElementById("share-button");
  if (!btn) throw new Error("Share button not found");

  const shareIcon = btn.querySelector(".share-icon") as HTMLElement;
  const checkIcon = btn.querySelector(".check-icon") as HTMLElement;
  const label = btn.querySelector(".feedback-label") as HTMLElement;

  let timeout: ReturnType<typeof setTimeout>;

  function showFeedback(text: string) {
    shareIcon.classList.add("hidden");
    checkIcon.classList.remove("hidden");
    label.textContent = text;
    label.classList.remove("hidden");
    clearTimeout(timeout);
    timeout = setTimeout(() => {
      shareIcon.classList.remove("hidden");
      checkIcon.classList.add("hidden");
      label.classList.add("hidden");
    }, 2000);
  }

  btn.addEventListener("click", async () => {
    const url = window.location.href;
    const title = document.title;

    if (navigator.share) {
      try {
        await navigator.share({ title, url });
        showFeedback("Shared!");
      } catch (e) {
        // User cancelled - do nothing
      }
    } else {
      try {
        await navigator.clipboard.writeText(url);
        showFeedback("Copied!");
      } catch {
        showFeedback("Error");
      }
    }
  });
</script>
