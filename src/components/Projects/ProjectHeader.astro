---
import { Image } from "astro:assets";
import { formatDate, type ProjectMetadata } from "../../lib/utils";
import GithubIcon from "../icons/GithubIcon.astro";
import NpmIcon from "../icons/NpmIcon.astro";
import PlayStoreIcon from "../icons/PlayStoreIcon.astro";
import SearchIcon from "../icons/SearchIcon.astro";

type Props = {
  project: ProjectMetadata;
};
const { project: p } = Astro.props;

enum Icons {
  github = "github",
  npm = "npm",
  playStore = "playStore",
}
const projectButtons: {
  link: string | undefined;
  label: string;
  icon: Icons;
}[] = [
  {
    link: p.data.githubLink,
    label: "View Source",
    icon: Icons.github,
  },
  {
    link: p.data.npmLink,
    label: "Link to NPM",
    icon: Icons.npm,
  },
  {
    link: p.data.playStoreLink,
    label: "Link to Play store",
    icon: Icons.playStore,
  },
].filter((p) => Boolean(p.link));

const iconMap: Record<Icons, Function> = {
  github: GithubIcon,
  playStore: PlayStoreIcon,
  npm: NpmIcon,
};

const projectLinks = projectButtons
  .map((p) => p.link)
  .filter((value) => value !== undefined);
const lastExistingButton = projectLinks[projectLinks.length - 1];

const isLastButton = (button: string) => lastExistingButton === button;
---

<header class="flex flex-col gap-2">
  <a
    title="Back to projects"
    href="/projects"
    class="text-ink/50 hover:text-ink transition-colors text-sm"
  >
    ← Back
  </a>

  <!-- Hero card -->
  <div
    class="relative overflow-hidden rounded-2xl min-h-[220px] md:min-h-[280px] flex items-end"
    style={{ backgroundColor: p.data.color ?? "transparent" }}
  >
    <!-- Top-right image — visible on all sizes, fades naturally -->
    <Image
      title={`Cover for ${p.data.title}`}
      class="absolute right-0 top-0 h-full w-auto max-w-[50%] object-cover object-left opacity-70 md:opacity-100"
      style={{ mixBlendMode: "multiply" }}
      src={p.data.cover}
      priority
      loading="eager"
      alt={p.data.title}
      width={480}
      height={360}
    />

    <!-- Right-side gradient so text stays readable -->
    <div
      class="absolute inset-y-0 left-0 w-2/3 bg-gradient-to-r from-[var(--c)] via-[var(--c)]/80 to-transparent pointer-events-none"
      style={`--c: ${p.data.color ?? "transparent"}`}
    >
    </div>

    <!-- Text content -->
    <div class="relative z-10 flex flex-col gap-2 p-5 md:p-8">
      <!-- Category + badges -->
      <div class="flex flex-wrap items-center gap-1.5">
        <span
          class="text-[11px] uppercase tracking-widest text-ink/50 font-medium"
          >{p.data.category}</span
        >
        {
          !p.data.endedAt && (
            <span class="flex items-center gap-1 rounded-full bg-black/10 px-2 py-px">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-400" />
              <span class="text-[10px] font-medium text-ink/60">Active</span>
            </span>
          )
        }
        {
          p.data.oss && (
            <span class="rounded-full bg-black/10 px-2 py-px text-[10px] uppercase tracking-wider text-ink/50">
              OSS
            </span>
          )
        }
      </div>

      <!-- Title -->
      <h1
        class="font-title text-4xl md:text-6xl leading-[0.93] tracking-tight text-ink/85 max-w-sm text-balance"
      >
        {p.data.title}
      </h1>

      <!-- Date -->
      <p class="text-sm text-ink/55">
        {formatDate(p.data.startedAt)}
        {" → "}
        {p.data.endedAt ? formatDate(p.data.endedAt) : "In Progress"}
      </p>
    </div>
  </div>

  <!-- Action links -->
  {
    (p.data.link || projectButtons.length > 0) && (
      <nav class="flex flex-wrap gap-2 pt-1">
        {p.data.link && (
          <a
            href={p.data.link}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl px-4 py-2 text-sm font-medium text-ink/80 transition-all hover:brightness-95"
            style={{ backgroundColor: p.data.color ?? "transparent" }}
          >
            <SearchIcon width={16} height={16} />
            Visit Project
          </a>
        )}
        {projectButtons.map((b) => {
          const Icon = iconMap[b.icon];
          return (
            <a
              href={b.link}
              target="_blank"
              rel="noopener noreferrer"
              title={b.label}
              class="inline-flex items-center gap-2 rounded-xl border border-ink/10 bg-background px-4 py-2 text-sm text-ink/60 transition-all hover:border-ink/25 hover:text-ink"
            >
              <Icon width={16} height={16} />
              <span class="hidden sm:inline">{b.label}</span>
            </a>
          );
        })}
      </nav>
    )
  }
</header>
