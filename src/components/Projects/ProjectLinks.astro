---
import { Icon } from "astro-icon/components";
import { getLocale, useTranslations } from "../../i18n/utils";
import type { ProjectMetadata } from "../../lib/utils";

type Props = { project: ProjectMetadata };
const { project: p } = Astro.props;
const { data } = p;
const locale = getLocale(Astro.currentLocale);
const t = useTranslations(locale);

const links = [
  data.link && {
    href: data.link,
    label: t("projects.links.visit"),
    sub: t("projects.links.live"),
    icon: "lucide:arrow-up-right",
    primary: true,
  },
  data.githubLink && {
    href: data.githubLink,
    label: t("projects.links.source"),
    sub: "GitHub",
    icon: "simple-icons:github",
    primary: false,
  },
  data.npmLink && {
    href: data.npmLink,
    label: t("projects.links.npm"),
    sub: t("projects.links.registry"),
    icon: "simple-icons:npm",
    primary: false,
  },
  data.playStoreLink && {
    href: data.playStoreLink,
    label: t("projects.links.playstore"),
    sub: t("projects.links.googlePlay"),
    icon: "simple-icons:googleplay",
    primary: false,
  },
].filter(Boolean) as {
  href: string;
  label: string;
  sub: string;
  icon: string;
  primary: boolean;
}[];
---

{
  links.length > 0 && (
    <section class="mt-10 pt-8 border-t border-ink/10">
      <p class="text-[11px] uppercase tracking-widest text-ink/35 mb-4 font-medium">
        {t("projects.links.links")}
      </p>
      <div class="flex flex-wrap gap-2">
        {links.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              "group flex items-center gap-3 rounded-xl border px-4 py-3",
              "transition-[transform,box-shadow,background-color,border-color] duration-300 ease-out",
              "hover:-translate-y-0.5 hover:shadow-md",
              link.primary
                ? "border-ink/15 bg-ink text-background hover:bg-ink/85 hover:shadow-ink/10"
                : "border-ink/10 bg-background text-ink hover:border-ink/20 hover:shadow-ink/5",
            ]}
          >
            <Icon
              name={link.icon}
              class:list={[
                "size-4 shrink-0 transition-[transform,opacity] duration-300 ease-out group-hover:scale-105",
                link.primary
                  ? "text-background/60 group-hover:text-background/90"
                  : "text-ink/35 group-hover:text-ink/65",
              ]}
            />
            <div class="flex flex-col leading-tight">
              <span class="text-sm font-medium">{link.label}</span>
              <span
                class:list={[
                  "text-[11px] transition-opacity duration-200 group-hover:opacity-100",
                  link.primary
                    ? "text-background/50 opacity-70"
                    : "text-ink/40 opacity-80",
                ]}
              >
                {link.sub}
              </span>
            </div>
            {!link.primary && (
              <Icon
                name="lucide:arrow-up-right"
                class="ml-auto size-3.5 shrink-0 text-ink/25 -translate-x-1 opacity-0 transition-[transform,opacity] duration-300 ease-out group-hover:translate-x-0 group-hover:opacity-60"
              />
            )}
          </a>
        ))}
      </div>
    </section>
  )
}
