---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import type { ProjectMetadata } from "../../lib/utils";

interface Props {
  projects: ProjectMetadata[];
}

const { projects } = Astro.props;
---

<ul class="flex flex-col" data-stagger="60">
  {
    projects.map((project, index) => {
      const { data, id: slug } = project;
      const { title, summary, color, cover, tech, endedAt, startedAt, client } =
        data;
      const year = (endedAt ?? startedAt).getFullYear();
      const isActive = !endedAt;
      const tags = (tech ?? []).slice(0, 3);

      return (
        <li
          data-reveal="bottom"
          data-easing="soft"
          class="group relative border-b border-ink/[0.06] last:border-0"
        >
          {/* Color accent bar */}
          <div
            class="absolute left-0 top-3 bottom-3 w-[2px] rounded-full opacity-0 transition-opacity duration-200 group-hover:opacity-100"
            style={{ backgroundColor: color }}
          />

          <a
            href={`/projects/${slug}`}
            class="flex items-center gap-5 py-4 pl-5 pr-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 focus-visible:ring-offset-2 rounded-r-xl"
          >
            {/* Thumbnail */}
            <div
              class="relative h-[60px] w-[60px] shrink-0 overflow-hidden rounded-xl"
              style={{ backgroundColor: color }}
            >
              <Image
                src={cover}
                alt={title}
                width={72}
                height={60}
                loading={index < 4 ? "eager" : "lazy"}
                class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[88%] rounded-md object-cover object-top transition-transform duration-300 group-hover:-translate-y-1"
              />
            </div>

            {/* Info */}
            <div class="flex min-w-0 flex-1 flex-col gap-1">
              <div class="flex items-baseline gap-2">
                <h3 class="truncate font-medium leading-snug transition-transform duration-200 group-hover:translate-x-0.5">
                  {title}
                </h3>
                {isActive && (
                  <span class="hidden shrink-0 items-center gap-1 sm:inline-flex">
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-400" />
                    <span class="text-[10px] text-emerald-600">Active</span>
                  </span>
                )}
                {client && !isActive && (
                  <span class="hidden shrink-0 rounded border border-ink/10 px-1.5 py-px text-[10px] text-ink/30 sm:inline">
                    {client}
                  </span>
                )}
              </div>
              <p class="line-clamp-1 text-sm text-ink/40">{summary}</p>
            </div>

            {/* Meta - desktop */}
            <div class="hidden shrink-0 items-center gap-4 md:flex">
              {tags.length > 0 && (
                <div class="flex items-center gap-1.5">
                  {tags.map((tag, i) => (
                    <>
                      {i > 0 && <span class="text-ink/20">·</span>}
                      <span class="text-xs text-ink/35">{tag}</span>
                    </>
                  ))}
                </div>
              )}
              <span class="w-9 text-right text-xs tabular-nums text-ink/25">
                {year}
              </span>
              <Icon
                name="lucide:arrow-right"
                aria-hidden="true"
                class="h-3.5 w-3.5 -translate-x-1 text-ink/40 opacity-0 transition-all duration-200 group-hover:translate-x-0 group-hover:opacity-100"
              />
            </div>

            {/* Arrow - mobile */}
            <Icon
              name="lucide:arrow-right"
              aria-hidden="true"
              class="h-3.5 w-3.5 shrink-0 -translate-x-1 text-ink/40 opacity-0 transition-all duration-200 group-hover:translate-x-0 group-hover:opacity-100 md:hidden"
            />
          </a>
        </li>
      );
    })
  }
</ul>
