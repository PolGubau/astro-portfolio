---
import { Image } from "astro:assets";
import { getLocale, localizePath } from "../../i18n/utils";
import { type ProjectMetadata, parseProjectId } from "../../lib/utils";

interface Props {
  project: ProjectMetadata;
  index: number;
}

const { project, index } = Astro.props;
const locale = getLocale(Astro.currentLocale);
const { data, id: rawId } = project;
const slug = parseProjectId(rawId).slug;
const { title, summary, color, cover: src, tech, endedAt, client } = data;
const isFirstLoad = index < 6;
const isActive = !endedAt;
const tags = (tech ?? []).slice(0, 3);
const titleSize = title.length > 14 ? "text-2xl" : "text-3xl";
---

<div
  class="group project-cascade relative flex h-64 cursor-pointer flex-col overflow-hidden md:h-96"
>
  <a
    href={localizePath(`/projects/${slug}`, locale)}
    title={title}
    class="relative flex h-full flex-col items-center justify-end overflow-hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40 focus-visible:ring-inset"
    style={{ backgroundColor: color }}
  >
    <!-- Title -->
    <header class="absolute top-5 left-5 z-30 flex flex-col gap-2">
      <h3 class:list={["font-medium leading-snug text-ink/90", titleSize]}>
        {title}
      </h3>
      <div class="flex items-center gap-1.5">
        {
          isActive && (
            <span class="flex items-center gap-1 rounded-full bg-background/10 px-2 py-0.5 backdrop-blur-sm">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-400" />
              <span class="text-[10px] font-medium text-ink/70">Active</span>
            </span>
          )
        }
        {
          client && (
            <span class="rounded-full bg-background/10 px-2 py-0.5 text-[10px] font-medium text-ink/70 backdrop-blur-sm">
              {client}
            </span>
          )
        }
      </div>
    </header>

    <!-- Screenshot: overflow-hidden clips the image; translate is on the image so no gap appears -->
    <div class="relative w-[90%] max-h-[58%] md:max-h-[65%] overflow-hidden">
      <Image
        src={src}
        priority={isFirstLoad}
        loading={isFirstLoad ? "eager" : "lazy"}
        alt={title}
        width={600}
        height={380}
        class="pointer-events-none w-full scale-[1.0] rounded-t-xl object-cover object-top transition-transform duration-500 ease-out group-hover:scale-[1.05]"
      />
    </div>

    <!-- Footer - slides up on hover -->
    <footer
      class="absolute bottom-0 left-0 right-0 z-10 flex flex-col gap-2 translate-y-full bg-gradient-to-t from-background via-background/70 to-transparent px-5 pb-2 pt-2 transition-transform duration-300 backdrop-blur-md ease-out group-hover:translate-y-0 rounded-t-3xl"
    >
      {
        tags.length > 0 && (
          <div class="mt-2.5 flex flex-wrap gap-1.5">
            {tags.map((tag) => (
              <span class="rounded-full bg-background/80 capitalize px-2 py-0.5 text-xs text-ink/70">
                {tag}
              </span>
            ))}
          </div>
        )
      }
      <p class="line-clamp-2 text-sm leading-relaxed text-ink">
        {summary}
      </p>
    </footer>
  </a>
</div>
