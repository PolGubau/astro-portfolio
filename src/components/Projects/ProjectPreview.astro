---
import { Image } from "astro:assets";
import type { ProjectMetadata } from "../../lib/utils";

interface Props {
  project: ProjectMetadata;
  index: number;
}

const { project, index } = Astro.props;
const { data, id: slug } = project;
const { title, summary, color, cover: src, tech, endedAt, oss } = data;
const isFirstLoad = index < 6;
const isActive = !endedAt;
const tags = (tech ?? []).slice(0, 3);
const titleSize = title.length > 14 ? "text-2xl" : "text-3xl";
---

<div
  class="group project-cascade relative flex h-64 cursor-pointer flex-col overflow-hidden md:h-96"
>
  <a
    href={`/projects/${slug}`}
    title={title}
    class="relative flex h-full flex-col items-center justify-end overflow-hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/40 focus-visible:ring-inset"
    style={{ backgroundColor: color }}
  >
    <!-- Title -->
    <header class="absolute top-5 left-5 z-10 flex flex-col gap-2">
      <h3 class:list={["font-medium leading-snug text-ink/80", titleSize]}>
        {title}
      </h3>
      <div class="flex items-center gap-1.5">
        {
          isActive && (
            <span class="flex items-center gap-1 rounded-full bg-black/10 px-2 py-0.5">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-400" />
              <span class="text-[10px] font-medium text-ink/60">Active</span>
            </span>
          )
        }
        {
          oss && (
            <span class="rounded-full bg-black/10 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider text-ink/50">
              OSS
            </span>
          )
        }
      </div>
    </header>

    <!-- Screenshot -->
    <div
      class="relative w-[90%] transition-transform duration-500 ease-out group-hover:-translate-y-2"
    >
      <Image
        src={src}
        priority={isFirstLoad}
        loading={isFirstLoad ? "eager" : "lazy"}
        alt={title}
        width={600}
        height={380}
        class="pointer-events-none w-full rounded-t-xl object-cover object-top"
      />
    </div>

    <!-- Footer - slides up on hover -->
    <footer
      class="absolute bottom-0 left-0 right-0 z-10 translate-y-full bg-gradient-to-t from-ink via-ink/70 to-transparent px-5 pb-5 pt-10 transition-transform duration-300 ease-out group-hover:translate-y-0"
    >
      <p class="line-clamp-2 text-sm leading-relaxed text-white/85">
        {summary}
      </p>
      {
        tags.length > 0 && (
          <div class="mt-2.5 flex flex-wrap gap-1.5">
            {tags.map((tag) => (
              <span class="rounded-full bg-white/15 px-2 py-0.5 text-xs text-white/70">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </footer>
  </a>
</div>
