---
// Reusable schema component for generating JSON-LD structured data
export interface SchemaProps {
  type:
    | "Person"
    | "Organization"
    | "WebSite"
    | "Article"
    | "BreadcrumbList"
    | "FAQPage"
    | "HowTo"
    | "CreativeWork"
    | "SoftwareApplication";
  data: Record<string, unknown>;
}

const { type, data } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": type,
  ...data,
};
---

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(schema)}
/>
