---
interface Props {
  href: string;
  className?: string;
  label: string;
}

const { href, label, className } = Astro.props;
---

<a
  href={href}
  class:list={[
    "flex w-fit select-none items-center gap-2 rounded-xl border border-ink/20 px-3 py-1 text-sm transition-colors hover:bg-ink/5 hover:border-ink/30",
    className,
  ]}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={label}
>
  <slot name="icon" />
  {label}
</a>
