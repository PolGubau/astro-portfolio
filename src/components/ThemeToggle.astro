---
// Theme Toggle Component
---

<button
  id="theme-toggle"
  type="button"
  class="group relative h-9 w-9 rounded-lg border border-foreground/10 bg-foreground/5 transition-all hover:border-foreground/20 hover:bg-foreground/10"
  aria-label="Toggle theme"
  title="Toggle theme"
>
  <!-- Sun Icon (light mode) -->
  <svg
    id="theme-toggle-light-icon"
    class="absolute left-1/2 top-1/2 h-5 w-5 -translate-x-1/2 -translate-y-1/2 transition-all"
    fill="currentColor"
    viewBox="0 0 20 20"
  >
    <path
      d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
      fill-rule="evenodd"
      clip-rule="evenodd"></path>
  </svg>

  <!-- Moon Icon (dark mode) -->
  <svg
    id="theme-toggle-dark-icon"
    class="absolute left-1/2 top-1/2 h-5 w-5 -translate-x-1/2 -translate-y-1/2 transition-all"
    fill="currentColor"
    viewBox="0 0 20 20"
  >
    <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
  </svg>
</button>

<script>
  const theme = (() => {
    // Check localStorage first
    if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
      return localStorage.getItem("theme");
    }
    // Then check system preference
    if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
      return "dark";
    }
    return "light";
  })();

  // Apply theme immediately to prevent flash
  if (theme === "dark") {
    document.documentElement.classList.add("dark");
  } else {
    document.documentElement.classList.remove("dark");
  }

  // Update icons
  function updateIcons() {
    const isDark = document.documentElement.classList.contains("dark");
    const lightIcon = document.getElementById("theme-toggle-light-icon");
    const darkIcon = document.getElementById("theme-toggle-dark-icon");

    if (isDark) {
      lightIcon?.classList.add("scale-0", "opacity-0");
      lightIcon?.classList.remove("scale-100", "opacity-100");
      darkIcon?.classList.remove("scale-0", "opacity-0");
      darkIcon?.classList.add("scale-100", "opacity-100");
    } else {
      lightIcon?.classList.remove("scale-0", "opacity-0");
      lightIcon?.classList.add("scale-100", "opacity-100");
      darkIcon?.classList.add("scale-0", "opacity-0");
      darkIcon?.classList.remove("scale-100", "opacity-100");
    }
  }

  // Handle page load
  document.addEventListener("DOMContentLoaded", () => {
    updateIcons();

    const button = document.getElementById("theme-toggle");
    button?.addEventListener("click", () => {
      const isDark = document.documentElement.classList.contains("dark");

      if (isDark) {
        document.documentElement.classList.remove("dark");
        localStorage.setItem("theme", "light");
      } else {
        document.documentElement.classList.add("dark");
        localStorage.setItem("theme", "dark");
      }

      updateIcons();
    });
  });

  // Handle Astro view transitions (if enabled in future)
  document.addEventListener("astro:page-load", () => {
    updateIcons();
  });
</script>

<style>
  #theme-toggle-light-icon,
  #theme-toggle-dark-icon {
    transition:
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>
