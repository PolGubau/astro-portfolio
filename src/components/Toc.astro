---
import type { MarkdownHeading } from "astro";

type Props = {
  headings: MarkdownHeading[];
};
const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth <= 3);
---

<nav
  id="toc"
  aria-label="Table of contents"
  class="hidden lg:flex flex-col gap-[6px] sticky top-24 w-10 self-start"
>
  {
    filtered.map(({ depth, slug, text }) => (
      <a
        href={`#${slug}`}
        data-toc-slug={slug}
        data-toc-depth={depth}
        aria-label={text}
        class="toc-item group relative flex items-center"
      >
        <span
          class:list={[
            "toc-bar block h-[2px] rounded-full transition-all duration-300",
            "bg-ink/20 group-hover:bg-ink/70",
            depth === 2 ? "w-7" : "w-4",
          ]}
        />
        <span class="toc-tooltip pointer-events-none absolute left-11 z-50 whitespace-nowrap rounded-md bg-ink px-2.5 py-1 text-xs text-background opacity-0 shadow-md transition-all duration-150 group-hover:opacity-100 group-hover:translate-x-0 -translate-x-1">
          {text}
        </span>
      </a>
    ))
  }
</nav>

<script>
  const items = document.querySelectorAll<HTMLAnchorElement>("[data-toc-slug]");
  const slugToEl = new Map<string, HTMLAnchorElement>();
  items.forEach((el) => slugToEl.set(el.dataset.tocSlug!, el));

  function setActive(slug: string) {
    slugToEl.forEach((el, s) => {
      const bar = el.querySelector(".toc-bar") as HTMLElement;
      const isActive = s === slug;
      bar.style.opacity = isActive ? "1" : "";
      bar.style.backgroundColor = isActive ? "var(--color-ink)" : "";
      bar.style.height = isActive ? "3px" : "";
      const depth = el.dataset.tocDepth;
      bar.style.width = isActive ? (depth === "2" ? "36px" : "22px") : "";
    });
  }

  const headings = Array.from(
    document.querySelectorAll<HTMLElement>(".prose h2, .prose h3"),
  );

  const observer = new IntersectionObserver(
    (entries) => {
      const visible = entries.filter((e) => e.isIntersecting);
      if (visible.length) setActive(visible[0].target.id);
    },
    { rootMargin: "-10% 0px -75% 0px", threshold: 0 },
  );

  headings.forEach((h) => observer.observe(h));
</script>
