---
import type { BlogMetadata } from "../../lib/utils";
import { blogs, getReadingTime } from "../../lib/utils";
import ClockIcon from "../icons/ClockIcon.astro";

type Props = {
  blog: BlogMetadata;
};

const similarTechProjects = (blog: BlogMetadata): BlogMetadata[] => {
  const tags = blog.data.tags ?? [];
  const otherBlogs = blogs.filter((post) => post.id !== blog.id);

  // Find blogs with matching tags
  const similarTechFiles = otherBlogs.filter((post) =>
    post.data.tags?.some((t) => tags.includes(t)),
  );

  // Sort by number of matching tags
  const sorted = similarTechFiles.sort((a, b) => {
    const aMatches = a.data.tags?.filter((t) => tags.includes(t)).length ?? 0;
    const bMatches = b.data.tags?.filter((t) => tags.includes(t)).length ?? 0;
    return bMatches - aMatches;
  });

  if (sorted.length >= 3) {
    return sorted.slice(0, 3);
  }

  // Fill with recent posts if not enough similar ones
  const remaining = 3 - sorted.length;
  const recentPosts = otherBlogs
    .filter((post) => !sorted.includes(post))
    .slice(0, remaining);

  return [...sorted, ...recentPosts];
};

const { blog } = Astro.props;
const similarPosts = similarTechProjects(blog);
---

{
  similarPosts.length > 0 && (
    <section class="mt-16">
      <h2 class="font-semibold text-2xl text-ink mb-6">Related Articles</h2>
      <div class="gap-4 grid md:grid-cols-2 lg:grid-cols-3">
        {similarPosts.map((post) => {
          const readingTime = getReadingTime(post.body ?? "");
          const commonTags =
            post.data.tags?.filter((t) => blog.data.tags?.includes(t)) || [];

          return (
            <a
              href={`/blog/${post.id}`}
              class="group flex flex-col gap-3 rounded-xl border border-neutral-200 bg-neutral-50 p-4 transition-all hover:border-neutral-300 hover:bg-neutral-100 hover:scale-[1.01]"
            >
              <h3 class="font-semibold text-md transition-colors line-clamp-2 group-hover:text-ink">
                {post.data.title}
              </h3>
              <p class="text-sm text-ink/60 line-clamp-2">
                {post.data.summary}
              </p>

              {commonTags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-auto">
                  {commonTags.slice(0, 2).map((tag) => (
                    <span class="px-2 py-0.5 rounded-full bg-ink/10 text-ink/70 text-xs font-medium">
                      {tag}
                    </span>
                  ))}
                </div>
              )}

              {readingTime && (
                <div class="flex items-center gap-1 text-xs text-ink/40">
                  <ClockIcon width={12} height={12} />
                  {readingTime} min read
                </div>
              )}
            </a>
          );
        })}
      </div>
    </section>
  )
}
