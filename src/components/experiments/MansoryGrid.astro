const sortedVideos = [...videos].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);
---

<div class="columns-1 gap-4 space-y-4 md:columns-2 lg:columns-3">
  {
    sortedVideos.map((video) => (
      <div class="mb-4 break-inside-avoid">
        <Video
          src={video.mp4}
          title={video.title}
          width={video.width}
          height={video.height}
          date={video.date}
          tech={video.tech}
          style={{
            aspectRatio: `${video.width} / ${video.height}`,
          }}
        />
      </div>
    ))
  }
</div>
