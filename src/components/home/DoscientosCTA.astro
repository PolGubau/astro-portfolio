---
import { Icon } from "astro-icon/components";
---

<section
  data-reveal="bottom"
  data-easing="soft"
  class="relative overflow-hidden flex flex-col gap-6 p-8 md:p-14 rounded-2xl bg-ink text-background"
>
  {/* Decorative blobs */}
  <div
    class="absolute -top-16 -right-16 w-72 h-72 rounded-full bg-primary/15 blur-3xl pointer-events-none"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute -bottom-20 -left-20 w-96 h-96 rounded-full bg-primary/8 blur-3xl pointer-events-none"
    aria-hidden="true"
  >
  </div>

  {/* Watermark "doscientos" */}
  <span
    class="absolute right-2 -bottom-4 text-[9rem] md:text-[11rem] leading-none font-bold font-title text-background/[0.04] select-none pointer-events-none"
    aria-hidden="true"
  >
    doscientos
  </span>

  <div class="relative flex flex-col gap-4">
    <span
      class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-primary/20 border border-primary/30 text-primary text-xs font-medium w-fit"
    >
      Dev Studio
    </span>
    <h2 class="text-2xl md:text-3xl font-medium">Need custom software?</h2>
    <p class="text-lg text-background/60 max-w-2xl">
      I co-founded <strong class="text-background">Doscientos</strong>, a dev
      agency building web and mobile applications for businesses.
    </p>
  </div>

  <div class="relative">
    <a
      href="https://doscientos.studio"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary text-ink font-medium hover:bg-primary-400 hover:shadow-xl hover:shadow-primary/20 transition-all"
    >
      Visit Doscientos
      <Icon name="lucide:external-link" class="w-4 h-4" aria-hidden="true" />
    </a>
  </div>
</section>
