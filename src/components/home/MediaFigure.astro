---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  caption: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="flex flex-col gap-3">
  <Image
    src={src}
    alt={alt}
    format="avif"
    width={600}
    height={400}
    loading="lazy"
    data-zoom
    class="w-full aspect-[4/3] object-cover rounded-xl border border-neutral-200 shadow-sm cursor-zoom-in"
  />
  <figcaption class="text-sm text-ink/50">{caption}</figcaption>
</figure>
