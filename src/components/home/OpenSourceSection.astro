---
import { Icon } from "astro-icon/components";
import { getLocale, useTranslations } from "../../i18n/utils";
import { metadata } from "../../lib/constants";
import type { ProjectMetadata } from "../../lib/utils";
import ProjectListRow from "../Projects/ProjectListRow.astro";
import NpmIcon from "../icons/NpmIcon.astro";
import VercelIcon from "../icons/VercelIcon.astro";

interface Props {
  projects: ProjectMetadata[];
}

const { projects } = Astro.props;
const locale = getLocale(Astro.currentLocale);
const t = useTranslations(locale);
---

<section class="flex flex-col gap-12">
  <div class="flex items-baseline justify-between gap-4">
    <h2
      data-reveal="bottom"
      data-speed="fast"
      class="text-3xl md:text-4xl font-medium"
    >
      {t("home.side.title")}
    </h2>
    <div class="flex items-center gap-6">
      <div class="hidden sm:flex items-center gap-3">
        <a
          href={metadata.links.npm}
          target="_blank"
          rel="noopener noreferrer"
          data-reveal="bottom"
          data-speed="fast"
          title={`${metadata.npmDownloads} npm downloads`}
          class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-red-50 border border-red-200 text-red-600 text-xs font-medium hover:bg-red-100 transition-colors shrink-0"
        >
          <NpmIcon class="w-3 h-3" aria-hidden="true" />
          <span>{metadata.npmDownloads}</span>
          <span class="hidden sm:inline text-red-400"
            >{t("home.side.downloads")}</span
          >
        </a>
        <span
          data-reveal="bottom"
          data-speed="fast"
          data-delay="80"
          title={`${metadata.vercelViews} views on Vercel-deployed projects`}
          class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-neutral-900 border border-neutral-800 text-neutral-100 text-xs font-medium shrink-0"
        >
          <VercelIcon class="w-3 h-3" aria-hidden="true" />
          <span class="hidden sm:inline"
            >{metadata.vercelViews} {t("home.side.views")}</span
          >
          <span class="sm:hidden">{metadata.vercelViews}</span>
        </span>
        <a
          href={metadata.links.github}
          target="_blank"
          data-reveal="bottom"
          data-speed="fast"
          data-delay="160"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex items-center gap-1 text-sm text-ink/50 hover:text-ink transition-colors shrink-0"
        >
          {t("home.viewAll")}
          <Icon
            name="lucide:arrow-right"
            class="w-3.5 h-3.5"
            aria-hidden="true"
          />
        </a>
      </div>
    </div>
  </div>
  <ProjectListRow projects={projects} />
</section>
