---
import { Image } from "astro:assets";
import exampleAnimated from "../../assets/media/other/example-animated.webp";
import examplePortfolio from "../../assets/media/other/example-portfolio.webp";
import exampleBlog from "../../assets/media/other/example-codedByPol.webp";
import exampleFlags from "../../assets/media/other/example-flags.webp";

const cards = [
  {
    id: "card_1",
    src: exampleAnimated,
    alt: "Performance stats showing 100/100 scores",
  },
  { id: "card_2", src: examplePortfolio, alt: "Lighthouse performance report" },
  { id: "card_3", src: exampleBlog, alt: "Technical blog performance metrics" },
  { id: "card_4", src: exampleFlags, alt: "Speed and optimization results" },
];
---

<section id="cards" class="flex flex-col gap-4">
  <header
    id="cards-header"
    class="flex flex-col gap-2 pt-20 items-center text-center w-full"
  >
    <h2 class="text-3xl md:text-4xl font-medium">I don't ship slow websites</h2>
    <p class="text-ink/50">
      100/100 on Lighthouse isn't a flex, it's the baseline.
    </p>
  </header>
  <ul class="sticked-cards" id="sticked-cards">
    {
      cards.map(({ id, src, alt }) => (
        <li class="card" id={id}>
          <Image
            src={src}
            alt={alt}
            decoding="async"
            loading="lazy"
            width={1280}
            height={1000}
          />
        </li>
      ))
    }
  </ul>
</section>

<script>
  // JS fallback for browsers without CSS scroll-driven animation support
  // (Firefox, Safari). Uses passive scroll + rAF — no layout thrashing.
  if (!CSS.supports("animation-timeline", "scroll()")) {
    const section = document.getElementById("cards");
    const cardImgs = Array.from(
      document.querySelectorAll<HTMLElement>(".card img"),
    );
    const NUM = cardImgs.length;

    // Mirror the CSS keyframe: scale = 1.1 - 0.1 * reverseIndex, at progress=1
    // At progress=0 → scale(1), at progress=1 → target scale
    function targetScale(i: number) {
      const reverseIndex = NUM - i; // 1-based reverse
      return 1.1 - 0.1 * reverseIndex;
    }

    let ticking = false;

    function update() {
      if (!section) return;
      const { top, height } = section.getBoundingClientRect();
      // progress 0→1 as section scrolls from entering to leaving viewport
      const progress = Math.max(
        0,
        Math.min(1, -top / (height - window.innerHeight)),
      );

      cardImgs.forEach((img, i) => {
        // Each card exits in sequence — map its own window within overall progress
        const start = (i / NUM) * 0.5;
        const end = (i + 1) / NUM;
        const p = Math.max(0, Math.min(1, (progress - start) / (end - start)));
        const scale = 1 + (targetScale(i) - 1) * p;
        img.style.transform = `scale(${scale.toFixed(4)})`;
      });

      ticking = false;
    }

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true },
    );

    update(); // initial state
  }
</script>
