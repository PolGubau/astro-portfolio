---
import { Image } from "astro:assets";
import exampleAnimated from "../../assets/media/other/example-animated.webp";
import exampleBlog from "../../assets/media/other/example-codedByPol.webp";
import exampleFlags from "../../assets/media/other/example-flags.webp";
import examplePortfolio from "../../assets/media/other/example-portfolio.webp";
import { getLocale, useTranslations } from "../../i18n/utils";

const locale = getLocale(Astro.currentLocale);
const t = useTranslations(locale);

const cards = [
  {
    id: "card_1",
    src: exampleAnimated,
    alt: "Performance stats showing 100/100 scores",
  },
  { id: "card_2", src: examplePortfolio, alt: "Lighthouse performance report" },
  { id: "card_3", src: exampleBlog, alt: "Technical blog performance metrics" },
  { id: "card_4", src: exampleFlags, alt: "Speed and optimization results" },
];
---

<section id="cards" class="flex flex-col gap-4">
  <header
    id="cards-header"
    class="flex flex-col gap-2 pt-20 items-center text-center w-full"
  >
    <h2 class="text-3xl md:text-4xl font-medium">{t("home.perf.title")}</h2>
    <p class="text-ink/50">{t("home.perf.subtitle")}</p>
  </header>
  <ul class="sticked-cards" id="sticked-cards">
    {
      cards.map(({ id, src, alt }) => (
        <li class="card" id={id}>
          <Image
            src={src}
            alt={alt}
            class="border-ink/20"
            decoding="async"
            loading="lazy"
            width={1280}
            height={1000}
          />
        </li>
      ))
    }
  </ul>
</section>

<script>
  // JS-driven for all browsers - consistent easing, 3D depth, brightness
  {
    const section = document.getElementById("cards");
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".card"));
    const NUM = cards.length;

    cards.forEach((c) => (c.style.transformOrigin = "center center"));

    const clamp = (v: number, lo: number, hi: number) =>
      Math.max(lo, Math.min(hi, v));

    // easeInOutCubic - feels physical
    const ease = (t: number) =>
      t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;

    // Gentler scale range: card 0 → 0.85, card 3 → 1.0
    const targetScale = (i: number) => 1 - 0.05 * (NUM - 1 - i);

    let ticking = false;

    function update() {
      if (!section) return;
      const { top, height } = section.getBoundingClientRect();
      const progress = clamp(-top / (height - window.innerHeight), 0, 1);

      cards.forEach((card, i) => {
        const start = (i / NUM) * 0.5;
        const end = (i + 1) / NUM;
        const p = ease(clamp((progress - start) / (end - start), 0, 1));

        const scale = 1 + (targetScale(i) - 1) * p;
        const brightness = 1 - 0.18 * ((NUM - 1 - i) / (NUM - 1)) * p;
        const shadowBlur = 12 + 40 * p;
        const shadowAlpha = (0.07 + 0.13 * p).toFixed(2);

        card.style.transform = `scale(${scale.toFixed(4)})`;
        card.style.filter = `brightness(${brightness.toFixed(3)})`;
        const img = card.querySelector("img");
        if (img)
          img.style.boxShadow = `0 ${(shadowBlur * 0.5).toFixed(0)}px ${shadowBlur.toFixed(0)}px rgba(0,0,0,${shadowAlpha})`;
      });

      ticking = false;
    }

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true },
    );

    update();
  }
</script>
