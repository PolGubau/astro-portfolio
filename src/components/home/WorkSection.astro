---
import { Icon } from "astro-icon/components";
import { getLocale, localizePath, useTranslations } from "../../i18n/utils";
import type { ProjectMetadata } from "../../lib/utils";
import ProjectListRow from "../Projects/ProjectListRow.astro";

interface Props {
  projects: ProjectMetadata[];
}

const { projects } = Astro.props;
const locale = getLocale(Astro.currentLocale);
const t = useTranslations(locale);
---

<section class="flex flex-col gap-12">
  <div class="flex items-baseline justify-between gap-4">
    <h2
      data-reveal="bottom"
      data-speed="fast"
      class="text-3xl md:text-4xl font-medium"
    >
      {t("home.work.title")}
    </h2>
    <a
      href={localizePath("/projects", locale)}
      data-reveal="bottom"
      data-speed="fast"
      class="inline-flex items-center gap-1 text-sm text-ink/50 hover:text-ink transition-colors shrink-0"
    >
      {t("home.viewAll")}
      <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" aria-hidden="true" />
    </a>
  </div>
  <ProjectListRow projects={projects} />
</section>
