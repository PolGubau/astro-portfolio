---
import {
  getLocale,
  localeTags,
  localizePath,
  useTranslations,
} from "../../i18n/utils";
import MainLayout from "../../layouts/MainLayout.astro";
import { metadata } from "../../lib/constants";
import { getLocalizedProjects, parseProjectId } from "../../lib/utils";
import ContentLanguageNotice from "../Layout/ContentLanguageNotice.astro";
import ProjectsList from "../Projects/ProjectList/ProjectsList.astro";

const locale = getLocale(Astro.currentLocale);
const t = useTranslations(locale);
const projects = getLocalizedProjects(locale);

const pageTitle = t("projects.meta.title");
const pageDescription = t("projects.meta.description");
const pageUrl = new URL(
  localizePath("/projects", locale),
  metadata.links.website,
).href;

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: pageUrl,
  inLanguage: localeTags[locale],
  numberOfItems: projects.length,
  itemListElement: projects.map((project, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: new URL(
      localizePath(`/projects/${parseProjectId(project.id).slug}`, locale),
      metadata.links.website,
    ).href,
    name: project.data.title,
  })),
};
---

<MainLayout title={pageTitle} description={pageDescription} type="website">
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(itemListSchema)}
  />
  <div class="flex flex-col gap-12 pt-12 md:pt-4">
    <header class="flex flex-col gap-3">
      <h1 class="text-2xl font-semibold tracking-tight">
        {t("projects.heading")}
      </h1>
      <p class="text-ink/60">{t("projects.subtitle")}</p>
      <ContentLanguageNotice message={t("projects.notice")} />
    </header>
    <ProjectsList projects={projects} />
  </div>
</MainLayout>
