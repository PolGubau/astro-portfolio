---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Layout/footer/footer.astro";
import MobileNavbar from "../components/Layout/header/mobile-navbar.astro";
import Navbar from "../components/Layout/header/navbar.astro";
import "@polgubau/astro-reveal/styles";
import { getLocale } from "../i18n/utils";

const locale = getLocale(Astro.currentLocale);

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article" | "profile";
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  className?: string;
  keywords?: string[];
}

const {
  title,
  description,
  image,
  type,
  publishedTime,
  modifiedTime,
  author,
  keywords,
  className,
} = Astro.props;
---

<html
  lang={locale}
  dir="ltr"
  class={"w-full overflow-x-clip overscroll-y-none"}
>
  <head>
    <!-- Prevent FOUC: apply stored/system theme before paint -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        if (stored === "dark" || (!stored && prefersDark)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      author={author}
      keywords={keywords}
      locale={locale}
    />
  </head>
  <body>
    <main class="flex min-h-screen w-full">
      <div id="progress"></div>

      <div
        class:list={[
          "flex w-full max-w-5xl flex-auto flex-col px-4 pb-28 md:mx-auto md:px-10 md:pb-0",
          className,
        ]}
      >
        <Navbar />
        <slot />
        <Footer />
        <MobileNavbar />
      </div>
    </main>
    <script>
      import "@polgubau/astro-reveal";
      import mediumZoom from "medium-zoom";
      mediumZoom(".prose img, [data-zoom]", {
        margin: 16,
        background: "rgba(0,0,0,0.75)",
      });
    </script>
  </body>
</html>
