---
import { Image } from "astro:assets";
import me from "../assets/media/me.webp";
import MainLayout from "../layouts/MainLayout.astro";
import { metadata } from "../lib/constants";

const PAGE_TITLE = `About - ${metadata.title}`;
const PAGE_DESCRIPTION =
  "Frontend Developer & Design Engineer based in Barcelona. Co-founder of Doscientos, creator of Pol-UI, and passionate about design systems and user experience.";

const thisYear = new Date().getFullYear();
const yearSince2018 = thisYear - 2018;

// FAQ Schema for better SEO
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Who is Pol Gubau Amores?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pol Gubau Amores is a Frontend Developer and Design Engineer with 8+ years of experience, based in Barcelona, Spain. He is the Co-Founder of Doscientos, a software development agency that has served 30+ clients, and the creator of Pol-UI, an open-source React component library.",
      },
    },
    {
      "@type": "Question",
      name: "What is Doscientos?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Doscientos is a software development agency co-founded by Pol Gubau in 2018. The agency specializes in web applications, mobile apps, and custom software solutions, having delivered 50+ projects for more than 30 clients worldwide.",
      },
    },
    {
      "@type": "Question",
      name: "What is Pol-UI?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pol-UI is an open-source React component library created by Pol Gubau. It focuses on accessibility, developer experience, and modern design patterns. The library is used by developers worldwide and continues to grow with community contributions.",
      },
    },
    {
      "@type": "Question",
      name: "What technologies does Pol Gubau specialize in?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pol Gubau specializes in React.js, TypeScript, Next.js, Astro, Tailwind CSS, Design Systems, Component Libraries, Web Accessibility (WCAG), Performance Optimization, and UI/UX Design. He has extensive experience building production-scale applications and design systems.",
      },
    },
    {
      "@type": "Question",
      name: "Where is Pol Gubau based?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pol Gubau is based in Barcelona, Spain. He works with clients worldwide and is fluent in English, Spanish, and Catalan.",
      },
    },
    {
      "@type": "Question",
      name: "How can I contact Pol Gubau?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "You can contact Pol Gubau via email at gubaupol@gmail.com, or connect through LinkedIn, GitHub, or Twitter. For business inquiries related to Doscientos, visit https://doscientos.es.",
      },
    },
  ],
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://polgubau.com/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "About",
      item: "https://polgubau.com/about",
    },
  ],
};
---

<MainLayout title={PAGE_TITLE} description={PAGE_DESCRIPTION} type="profile">
  <!-- JSON-LD Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />

  <div class="py-20">
    <!-- Header -->
    <header class="mb-16 text-center md:text-left">
      <div class="flex flex-col items-center gap-8 md:flex-row md:items-start">
        <Image
          src={me}
          alt="Pol Gubau Amores"
          width={160}
          height={160}
          class="h-32 w-32 rounded-full object-cover ring-4 ring-foreground/10 md:h-40 md:w-40"
        />
        <div class="flex-1">
          <h1 class="font-title text-4xl font-bold tracking-tight md:text-5xl">
            About Me
          </h1>
          <p class="mt-4 text-xl text-foreground/70">
            Frontend Developer & Design Engineer
          </p>
          <p class="mt-2 text-foreground/50">
            Barcelona, Spain • {yearSince2018}+ years of experience
          </p>
        </div>
      </div>
    </header>

    <!-- Content -->
    <div class="mx-auto max-w-3xl space-y-12">
      <!-- Story -->
      <section class="space-y-6">
        <h2 class="font-title text-2xl font-bold md:text-3xl">My Journey</h2>
        <div class="space-y-4 text-lg leading-relaxed text-foreground/70">
          <p>
            I started my career as a <strong>graphic designer</strong> and gradually
            transitioned into
            <strong>frontend development</strong>, combining my eye for design
            with technical expertise. Today, I specialize in building design
            systems, component libraries, and accessible user interfaces.
          </p>
          <p>
            In 2018, I co-founded <a
              href="https://doscientos.es"
              target="_blank"
              rel="noopener noreferrer"
              class="font-semibold text-foreground underline decoration-foreground/30 hover:text-primary transition-colors"
              >Doscientos</a
            >, a software development agency that has delivered solutions for <strong
              >30+ clients</strong
            > across various industries. From startups to established companies, we've
            built everything from MVPs to production-scale applications.
          </p>
          <p>
            I also created <a
              href="https://pol-ui.com"
              target="_blank"
              rel="noopener noreferrer"
              class="font-semibold text-foreground underline decoration-foreground/30 hover:text-primary transition-colors"
              >Pol-UI</a
            >, an open-source React component library focused on accessibility
            and developer experience. It's used by developers worldwide and
            continues to grow with community contributions.
          </p>
        </div>
      </section>

      <!-- Tech Stack -->
      <section class="space-y-6">
        <h2 class="font-title text-2xl font-bold md:text-3xl">
          What I Work With
        </h2>
        <div class="grid gap-6 md:grid-cols-2">
          <div>
            <h3 class="mb-3 font-semibold text-foreground">Frontend</h3>
            <ul class="space-y-2 text-foreground/70">
              <li>• React, Next.js, Astro</li>
              <li>• TypeScript, JavaScript</li>
              <li>• Tailwind CSS, CSS-in-JS</li>
              <li>• Design Systems, Component Libraries</li>
            </ul>
          </div>
          <div>
            <h3 class="mb-3 font-semibold text-foreground">Tools & More</h3>
            <ul class="space-y-2 text-foreground/70">
              <li>• Figma, Adobe Creative Suite</li>
              <li>• Git, GitHub, CI/CD</li>
              <li>• Supabase, Vercel, Netlify</li>
              <li>• Accessibility (WCAG, ARIA)</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Values -->
      <section class="space-y-6">
        <h2 class="font-title text-2xl font-bold md:text-3xl">
          What I Believe In
        </h2>
        <div class="space-y-4 text-lg leading-relaxed text-foreground/70">
          <p>
            <strong>Design systems are the future.</strong> They enable teams to build
            faster, maintain consistency, and scale products without sacrificing quality.
          </p>
          <p>
            <strong>Accessibility is not optional.</strong> Every user deserves a
            great experience, regardless of their abilities or the device they're
            using.
          </p>
          <p>
            <strong>Code should be simple.</strong> The best solutions are often the
            simplest ones. I prioritize clarity, maintainability, and performance
            over cleverness.
          </p>
        </div>
      </section>

      <!-- Beyond Work -->
      <section class="space-y-6">
        <h2 class="font-title text-2xl font-bold md:text-3xl">Beyond Code</h2>
        <div class="space-y-4 text-lg leading-relaxed text-foreground/70">
          <p>
            When I'm not coding, you'll find me exploring new design trends,
            contributing to open-source projects, or sharing insights through
            technical writing. I occasionally speak at local institutions about
            frontend development and software entrepreneurship.
          </p>
          <p>
            I'm based in <strong>Barcelona, Spain</strong>, and available for
            consulting, partnerships, and interesting projects through <a
              href="https://doscientos.es"
              class="font-semibold text-foreground underline decoration-foreground/30 hover:text-primary transition-colors"
              >Doscientos</a
            >.
          </p>
        </div>
      </section>

      <!-- Contact -->
      <section
        class="rounded-xl border border-foreground/10 bg-foreground/5 p-8 text-center md:p-12"
      >
        <h2 class="font-title text-2xl font-bold md:text-3xl">Get in Touch</h2>
        <p class="mt-3 text-lg text-foreground/60">gubaupol@gmail.com</p>
        <div
          class="mt-6 flex flex-wrap items-center justify-center gap-4 text-sm"
        >
          <a
            href="https://github.com/PolGubau"
            target="_blank"
            rel="noopener noreferrer"
            class="text-foreground/60 transition-colors hover:text-foreground"
          >
            GitHub
          </a>
          <span class="text-foreground/30">•</span>
          <a
            href="https://www.linkedin.com/in/polgubau/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-foreground/60 transition-colors hover:text-foreground"
          >
            LinkedIn
          </a>
          <span class="text-foreground/30">•</span>
          <a
            href="https://twitter.com/PolGubau"
            target="_blank"
            rel="noopener noreferrer"
            class="text-foreground/60 transition-colors hover:text-foreground"
          >
            Twitter
          </a>
          <span class="text-foreground/30">•</span>
          <a
            href="/files/PolGubau_CV.pdf"
            target="_blank"
            rel="noreferrer"
            class="text-foreground/60 transition-colors hover:text-foreground"
          >
            Resume
          </a>
        </div>
      </section>
    </div>
  </div>
</MainLayout>
