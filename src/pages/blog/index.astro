---
import MainLayout from "../../layouts/MainLayout.astro";
import { metadata } from "../../lib/constants";
import { getBlogs } from "../../lib/utils";

const allBlogs = getBlogs();

const PAGE_TITLE = `Writing - ${metadata.title}`;
const PAGE_DESCRIPTION =
	"Technical writing on web development, design systems, and modern frontend.";

function formatDate(d: Date) {
	const fullDate = d.toLocaleString("en-us", {
		month: "short",
		day: "numeric",
		year: "numeric",
	});
	return fullDate;
}
---

<MainLayout title={PAGE_TITLE} description={PAGE_DESCRIPTION} type="website">
	<div class="flex flex-col gap-12">
		<header class="flex flex-col gap-3">
			<h1 class="text-2xl font-semibold tracking-tight">Writing</h1>
			<p class="text-foreground/60">
				Technical articles on web development and design
			</p>
		</header>

		<ul class="flex flex-col gap-8">
			{
				allBlogs.map((post) => (
					<li>
						<a
							href={`/blog/${post.id}`}
							class="group flex flex-col gap-2 transition-opacity hover:opacity-70"
						>
							<h2 class="text-lg font-medium group-hover:text-primary transition-colors">
								{post.data.title}
							</h2>
							<p class="text-sm text-foreground/60">{post.data.summary}</p>
							<time
								datetime={post.data.publishedAt.toISOString()}
								class="text-xs text-foreground/50"
							>
								{formatDate(post.data.publishedAt)}
							</time>
						</a>
					</li>
				))
			}
		</ul>
	</div>
</MainLayout>
