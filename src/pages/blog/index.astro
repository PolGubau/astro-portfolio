---
import MainLayout from "../../layouts/MainLayout.astro";
import { metadata } from "../../lib/constants";
import { formatDate, getBlogs } from "../../lib/utils";

const allBlogs = getBlogs();

const PAGE_TITLE = `Writing — ${metadata.name}`;
const PAGE_DESCRIPTION =
	"Technical writing on web development, design systems, and modern frontend.";
---

<MainLayout title={PAGE_TITLE} description={PAGE_DESCRIPTION} type="website">
	<div class="flex flex-col gap-12">
		<header class="flex flex-col gap-3">
			<h1 class="text-2xl font-semibold tracking-tight">Writing</h1>
			<p class="text-ink/60">
				Technical articles on web development and design
			</p>
		</header>

		<ul class="flex flex-col divide-y divide-neutral-200">
			{
				allBlogs.map((post) => (
					<li>
						<a
							href={`/blog/${post.id}`}
							class="group -mx-3 flex items-start justify-between gap-8 rounded-lg px-3 py-6 transition-colors hover:bg-ink/[0.03] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 focus-visible:ring-offset-2"
						>
							<div class="flex min-w-0 flex-col gap-1.5">
								<h2 class="text-base font-medium text-ink text-pretty transition-transform group-hover:translate-x-0.5">
									{post.data.title}
								</h2>
								<p class="text-sm text-ink/50 text-pretty">
									{post.data.summary}
								</p>
							</div>
							<div class="flex shrink-0 items-center gap-2 pt-0.5">
								<time
									datetime={post.data.publishedAt.toISOString()}
									class="text-xs text-ink/40 tabular-nums"
								>
									{formatDate(post.data.publishedAt)}
								</time>
								<span
									aria-hidden="true"
									class="text-ink/30 opacity-0 transition-opacity group-hover:opacity-100"
								>
									→
								</span>
							</div>
						</a>
					</li>
				))
			}
		</ul>
	</div>
</MainLayout>
