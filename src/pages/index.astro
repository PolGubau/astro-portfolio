---
import Header from "../components/Layout/header/header.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { getProjects } from "../lib/utils";
import WorkSection from "../components/home/WorkSection.astro";
import OpenSourceSection from "../components/home/OpenSourceSection.astro";
import BeyondCodeSection from "../components/home/BeyondCodeSection.astro";
import DoscientosCTA from "../components/home/DoscientosCTA.astro";
import PerformanceCards from "../components/home/PerformanceCards.astro";
import "../styles/cards.css";

const allProjects = getProjects();
const ossProjects = allProjects.filter((p) => p.data.oss);
const workProjects = allProjects.filter((p) => !p.data.oss).slice(0, 6);
---

<MainLayout>
  <div>
    <Header />
    <main class="flex w-full flex-1 flex-col gap-20 md:gap-32">
      <WorkSection projects={workProjects} />
      <OpenSourceSection projects={ossProjects} />
      <BeyondCodeSection />
      <DoscientosCTA />
      <PerformanceCards />
    </main>
  </div>
</MainLayout>
