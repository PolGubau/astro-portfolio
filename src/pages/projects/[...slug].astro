---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ProjectBar from "../../components/Projects/ProjectBar.astro";
import ProjectHeader from "../../components/Projects/ProjectHeader.astro";
import ProjectLinks from "../../components/Projects/ProjectLinks.astro";
import SimilarProjects from "../../components/Projects/SimilarProjects.astro";
import Toc from "../../components/Toc.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import MdLayout from "../../layouts/MdLayout.astro";
import { metadata } from "../../lib/constants";
import { getProjects } from "../../lib/utils";

export async function getStaticPaths() {
  return getProjects().map((project) => ({
    params: { slug: project.id },
    props: project,
  }));
}
type Props = CollectionEntry<"projects">;

const project = Astro.props;

const PAGE_TITLE = `${project.data.seoTitle ?? project.data.title} - ${metadata.name}`;
const { Content, headings } = await render(project);
const publishedTime = project.data.startedAt.toISOString();
const modifiedTime = (
  project.data.endedAt ?? project.data.startedAt
).toISOString();

const projectPageUrl = `${metadata.links.website}/projects/${project.id}`;
const ogImage = `${metadata.links.website}/og/projects/${project.id}.png`;

// Build JSON-LD: SoftwareSourceCode when a GitHub repo is present, CreativeWork otherwise
const projectSchema = project.data.githubLink
  ? {
      "@context": "https://schema.org",
      "@type": "SoftwareSourceCode",
      name: project.data.title,
      description: project.data.summary,
      url: projectPageUrl,
      image: ogImage,
      codeRepository: project.data.githubLink,
      ...(project.data.tech?.length
        ? { programmingLanguage: project.data.tech }
        : {}),
      dateCreated: project.data.startedAt.toISOString().split("T")[0],
      ...(project.data.endedAt
        ? { dateModified: project.data.endedAt.toISOString().split("T")[0] }
        : {}),
      author: {
        "@type": "Person",
        name: metadata.longName,
        url: metadata.links.website,
      },
    }
  : {
      "@context": "https://schema.org",
      "@type": "CreativeWork",
      name: project.data.title,
      description: project.data.summary,
      url: projectPageUrl,
      image: ogImage,
      ...(project.data.link ? { sameAs: project.data.link } : {}),
      ...(project.data.tech?.length
        ? { keywords: project.data.tech.join(", ") }
        : {}),
      dateCreated: project.data.startedAt.toISOString().split("T")[0],
      ...(project.data.endedAt
        ? { dateModified: project.data.endedAt.toISOString().split("T")[0] }
        : {}),
      ...(project.data.client
        ? {
            producer: {
              "@type": "Organization",
              name: project.data.client,
            },
          }
        : {}),
      author: {
        "@type": "Person",
        name: metadata.longName,
        url: metadata.links.website,
      },
    };
---

<MainLayout
  image={`/og/projects/${project.id}.png`}
  title={PAGE_TITLE}
  description={project.data.summary}
  type="article"
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  keywords={project.data.tech && project.data.tech.length > 0
    ? project.data.tech
    : undefined}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(projectSchema)}
  />
  <section class="relative flex flex-col gap-4">
    <Breadcrumb
      items={[
        { name: "Home", url: "/" },
        { name: "Projects", url: "/projects" },
        { name: project.data.title },
      ]}
    />

    <ProjectHeader project={project} />

    <MdLayout backTo="/projects">
      <Content />
      {headings?.length > 0 && <Toc slot="toc" headings={headings} />}
      <ProjectLinks slot="footer" project={project} />
    </MdLayout>
    <SimilarProjects project={project} />

    {project.data.link ? <ProjectBar project={project} /> : null}
  </section>
</MainLayout>
