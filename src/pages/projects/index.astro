---
import ProjectsList from "../../components/Projects/ProjectList/ProjectsList.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { projects } from "../../lib/utils";

const PAGE_TITLE = "Projects - Web, Mobile & Open Source Work by Pol Gubau";
const PAGE_DESCRIPTION =
  "Explore 50+ projects by Pol Gubau Amores across React, TypeScript, and React Native - web apps, design systems, mobile apps, and freelance work, from open source libraries to client products.";

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: PAGE_TITLE,
  description: PAGE_DESCRIPTION,
  url: "https://polgubau.com/projects",
  numberOfItems: projects.length,
  itemListElement: projects.map((project, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: `https://polgubau.com/projects/${project.id}`,
    name: project.data.title,
  })),
};
---

<MainLayout title={PAGE_TITLE} description={PAGE_DESCRIPTION}>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(itemListSchema)}
  />
  <div class="flex flex-col gap-12 pt-12 md:pt-4">
    <header class="flex flex-col gap-3">
      <h1 class="text-2xl font-semibold tracking-tight">Projects</h1>
      <p class="text-ink/60">
        A selection of work across web, mobile, open source and freelance.
      </p>
    </header>
    <ProjectsList projects={projects} />
  </div>
</MainLayout>
